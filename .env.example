# AWS General
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Cognito — single confidential App Client for the BFF (sistema-c-bff)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_REGION=us-east-1
COGNITO_CLIENT_ID=your_bff_client_id
COGNITO_CLIENT_SECRET=your_bff_client_secret
COGNITO_DOMAIN=sistema-c-auth.auth.us-east-1.amazoncognito.com
COGNITO_JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX/.well-known/jwks.json
COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback

# KMS
KMS_KEY_ID=your_cmk_key_id

# S3 — bucket privado de fotos de perfil (creado manualmente en AWS).
# Opcional: si se omite se usa este valor por defecto. Región = AWS_REGION.
S3_BUCKET_PROFILE_PICTURES=wfn-profile-pictures

# DynamoDB — tablas del módulo de vacaciones (creadas manualmente en AWS).
# Opcionales: si se omiten, se usan estos mismos valores por defecto.
DDB_TABLE_VACATION_REQUESTS=wfn-vacation-requests
DDB_TABLE_VACATION_BALANCES=wfn-vacation-balances
DDB_TABLE_ORG_NODES=wfn-org-nodes
DDB_TABLE_AUDIT_LOGS=wfn-audit-logs

# BFF session (iron-session)
SESSION_SECRET=replace_with_at_least_32_characters_random_string_here
SESSION_COOKIE_NAME=sistema_c_session

# Allowed SPA origins (CORS + post-login redirect)
FRONTEND_URL_A=http://localhost:5173
FRONTEND_URL_B=http://localhost:5174
# Orígenes extra permitidos (CORS + return_to/logout), separados por comas.
# FRONTEND_URL_A/B ya se incluyen automáticamente; aquí agregas compañeros,
# Netlify, Vercel, etc. Ej:
# ALLOWED_ORIGINS=https://mi-a.netlify.app,https://mi-b.vercel.app
ALLOWED_ORIGINS=

# App
PORT=3000
NODE_ENV=development
