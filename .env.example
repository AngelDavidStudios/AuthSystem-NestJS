# AWS General
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_REGION=us-east-1
COGNITO_CLIENT_ID_A=your_sistema_a_client_id
COGNITO_CLIENT_SECRET_A=your_sistema_a_client_secret
COGNITO_CLIENT_ID_B=your_sistema_b_client_id
COGNITO_DOMAIN=sistema-c-auth.auth.us-east-1.amazoncognito.com
COGNITO_JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_XXXXXXXXX/.well-known/jwks.json

# KMS
KMS_KEY_ID=your_cmk_key_id

# App
PORT=3000
NODE_ENV=development