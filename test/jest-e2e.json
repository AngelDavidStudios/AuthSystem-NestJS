{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "roots": ["<rootDir>"],
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^jwks-rsa$": "<rootDir>/utils/jwks-rsa.stub.ts"
  },
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/setup-e2e.ts"]
}
